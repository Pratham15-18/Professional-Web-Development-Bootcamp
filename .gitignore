# Ignore OS files
.DS_Store
Thumbs.db
Desktop.ini

# Ignore editor folders and workspace settings
.vscode/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates

# Ignore dependency directories
node_modules/

# Ignore build/dist outputs
dist/
build/
coverage/

# Ignore environment files
.env
.env.local
.env.*.local

# Ignore log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Ignore temporary files
*.tmp
*.temp
*.swp
*.swo
*~

# Ignore archives and generated assets
*.zip
*.tar.gz
*.rar

# Optional: ignore published site output
public/
